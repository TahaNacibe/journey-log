{
  "name": "electron-react-template",
  "private": true,
  "version": "1.0.0",
  "main": "dist-electron/main.js",
  "description": "A generic Electron app template with React and TypeScript",
  "author": "Your Name",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "vite:dev": "vite",
    "vite:build": "npm run build && cross-env NODE_ENV=production electron-builder"
  },
  "build": {
    "appId": "com.yourcompany.electron-react-template",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist-electron/**/*",
      "dist-vite/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "./assets/icon.ico"
    }
  },
  "dependencies": {
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react-i18next": "^17.0.7",
    "react-resizable-panels": "^4.11.1",
    "react-router-dom": "^7.15.0",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "lucide-react": "^1.14.0",
    "postcss": "^8.5.14",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
